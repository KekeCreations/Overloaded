$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #132533);
  Anchor: (Width: 800, Height: 700);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #22425b);
    Label #TITLE {
      Text: "OVERLOADED";
      Style: (TextColor: #408080, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "MADE BY KEKECREATIONS";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #Sep {
    LayoutMode: Top;
    Background: (Color: #408080);
    Anchor: (Height: 10);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #132533);
    Anchor: (Width: 150, Height: 530, Left: 325, Top: 40);
    $C.@TextButton #PLAYCLASSIC {
      Background: (Color: #ffffff);
      Anchor: (Width: 110, Height: 50, Left: 0, Right: 0);
      Text: "PLAY CLASSIC";
    }
    $C.@TextButton #PLAYQUICK {
      Background: (Color: #ffffff);
      Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "PLAY QUICK";
    }
    $C.@TextButton #PLAYROUNDS {
      Background: (Color: #ffffff);
      Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "PLAY ROUNDS";
    }
    $C.@TextButton #SETTINGS {
      Background: (Color: #ffffff);
      Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "SETTINGS";
    }
    $C.@TextButton #HOWTOPLAY {
      Anchor: (Height: 30, Top: 40);
      Text: "HOW TO PLAY";
    }
    $C.@CancelTextButton #QUIT {
      Anchor: (Height: 50, Top: 100);
      Text: "QUIT";
    }
  }
}