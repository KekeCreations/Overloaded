          Background: (Color: #998033);
          Anchor: (Height: 15, Top: 10);
        }
      }
      Group #BUTTONS {
        LayoutMode: Top;
        Anchor: (Width: 150, Height: 530, Left: 315, Top: 20);
        $C.@TextButton #PLAYCLASSIC {
          Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 0);
          Text: "PLAY CLASSIC";
        }
        $C.@TextButton #PLAYROUNDS {
          Background: (Color: #ffffff);
          Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
          Text: "PLAY ROUNDS";
        }
        $C.@TextButton #PLAYQUICK {
          Background: (Color: #ffffff);
          Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
          Text: "PLAY QUICK";
        }
        $C.@TextButton #PLAYCHAOS {
