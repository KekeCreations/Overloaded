// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #998033);
  Anchor: (Width: 800, Height: 700);
  Group #BODY {
    LayoutMode: Top;
    Background: (Color: #725f25);
    Anchor: (Width: 780, Height: 680, Left: 10, Top: 10);
    Group #INNERBODY {
      LayoutMode: Top;
      Background: (Color: #1e3d53);
      Anchor: (Width: 760, Height: 660, Left: 10, Top: 10);
      Group #TEXT {
        LayoutMode: Top;
        Background: (Color: #244964);
        Group #TITLELAYOUT {
          LayoutMode: Middle;
          Anchor: (Width: 700, Height: 100, Top: 10);
          AssetImage #TITLE {
            Anchor: (Width: 700, Height: 100);
            AssetPath: "UI/Custom/Pages/Textures/Gameover.png";
          }
        }
        Group #Sep {
          LayoutMode: Top;
          Background: (Color: #998033);
          Anchor: (Height: 10, Top: 10);
        }
      }
      Label #ROUNDS {
        Anchor: (Top: 30);
        Text: "YOU SURVIVED 0 ROUNDS";
        Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
      }
      Label #ROUNDTYPE {
        Anchor: (Top: 10);
        Text: "GAMEMODE:";
        Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
      }
      Label #KILLS {
        Anchor: (Top: 5);
        Text: "ENEMIES KILLED:";
        Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
      }
      Label #GOLD {
        Anchor: (Top: 5);
        Text: "GOLD COLLECTED:";
        Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
      }
      Group #BUTTONS {
        LayoutMode: Top;
        Anchor: (Width: 250, Height: 330, Left: 260, Top: 40);
        $C.@TextButton #PLAYAGAIN {
          Background: (Color: #ffffff);
          Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
          Text: "PLAY AGAIN";
        }
        $C.@TextButton #SETTINGS {
          Background: (Color: #ffffff);
          Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
          Text: "SETTINGS";
        }
      }
    }
  }
}