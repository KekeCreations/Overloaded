// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #132533);
  Anchor: (Width: 800, Height: 700);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #22425b);
    Label #TITLE {
      Text: "GAME OVER";
      Style: (TextColor: #408080, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "LOOK HOW WELL YOU DID!";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #Sep {
    LayoutMode: Top;
    Background: (Color: #408080);
    Anchor: (Height: 10);
  }
  Label #ROUNDS {
    Anchor: (Top: 30);
    Text: "YOU SURVIVED 0 ROUNDS";
    Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
  }
  Label #ROUNDTYPE {
    Anchor: (Top: 10);
    Text: "GAMEMODE:";
    Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
  }
  Label #KILLS {
    Anchor: (Top: 5);
    Text: "ENEMIES KILLED:";
    Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
  }
  Label #GOLD {
    Anchor: (Top: 5);
    Text: "GOLD COLLECTED:";
    Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #132533);
    Anchor: (Width: 250, Height: 330, Left: 280, Top: 40);
    $C.@TextButton #PLAYAGAIN {
      Background: (Color: #ffffff);
      Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "PLAY AGAIN";
    }
    $C.@TextButton #SETTINGS {
      Background: (Color: #ffffff);
      Anchor: (Width: 110, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "SETTINGS";
    }
  }
}